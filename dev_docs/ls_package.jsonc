{
  // 1. 清单格式版本，用于未来兼容
  "schema_version": 1,

  // 2. 包基本标识
  "type": "game",                      // "game" | "screensaver" | "boss"
  "package": "com.example.mygame",     // 唯一包名
  "version": "1.0.0",                 // 语义化版本，也可以使用语义字符串
  "version_code": 1,                  // 整数，严格递增，宿主内部判断用的版本序号

  // 3. 兼容的宿主 API 版本
  "api": {
    "min": 1, // min必须小于等于max，或填写单一数字 "api": int
    "max": 2
  },

  // 4. 入口脚本（所有包都必须有，可以不写后缀，宿主会自动检测文件类型）
  "entry": "init.lua",

  // 5. 包展示信息
  "display": {
    "title": "My Game Pack",              // 包名（原 package_name）
    "description": "A collection of classic terminal games.", // 包简介（原 introduction）
    "author": "Alex",
    "icon": "pack_icon.png",              // 包的图标（或字符画）
    "banner": "pack_banner.png"
  },

  // 6. 运行时公共配置（只有游戏包需要）
  "runtime": {
    "min_width": 60,
    "min_height": 20,
    "write": false,
    "target_fps": 30,
    "afk_time": 120
  },

  // 7. 类型专属配置块
  "game": {
    "name": "Minefield",                  // 游戏显示名（原 game_name）
    "detail": "A full-featured minesweeper...",   // 游戏详细描述（原 detail）
    "write": false, // 写请求
    "save": true, // 是否可存档
    "best_score": true, // 是否需要记录最佳分数
    "best_none": "", // 空（无记录）时显示的字符串（best_score为false会被忽略)
    "actions": { ... }
  },

  // 如果是屏保包，则会有 "screensaver": { ... } 块
  "screensaver": {
    "name": "Minefield",                  // 游戏显示名（原 game_name）
    "detail": "A full-featured minesweeper..."   // 游戏详细描述（原 detail）
  },

  // 如果是老板包，则会有 "boss": { ... } 块
  "boss": {
    "name": "Minefield",                  // 游戏显示名（原 game_name）
    "detail": "A full-featured minesweeper..."   // 游戏详细描述（原 detail）
  }
}